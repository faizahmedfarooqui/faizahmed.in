---
// Self-hosted Ubuntu Mono (latin subset) — bundled into _astro, no runtime CDN
// and no render-blocking @import chain. font-display: swap is set by fontsource.
import "@fontsource/ubuntu-mono/latin-400.css";
import "@fontsource/ubuntu-mono/latin-400-italic.css";
import "@fontsource/ubuntu-mono/latin-700.css";
import "@fontsource/ubuntu-mono/latin-700-italic.css";
import "../styles/global.css";
import BaseHead from "../components/BaseHead.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import Search from "../components/Search.astro";

interface Props {
  title?: string;
  description?: string;
  canonicalPath: string;
  image?: string | null;
  type?: "website" | "article";
  publishedTime?: Date;
  jsonLd?: object | object[];
  feed?: { title: string; href: string };
  noindex?: boolean;
}
const props = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <BaseHead {...props} />
    {/* Umami Cloud — cookieless analytics, production only (no localhost noise). */}
    {import.meta.env.PROD && (
      <script
        is:inline
        defer
        src="https://cloud.umami.is/script.js"
        data-website-id="c7d523fd-446c-4fa9-af93-7c096a4310fb"
      ></script>
    )}
  </head>
  <body>
    <a href="#main-content" class="skip-link">Skip to content</a>
    <Header />
    <main id="main-content" class="wrap">
      <slot />
    </main>
    <Footer />
    <Search />

    <script>
      // Render any Mermaid diagrams (server-emitted <pre class="mermaid">).
      // NOTE: we import Mermaid asynchronously and Rocket Loader defers this
      // script, so the `load` event has already fired by the time Mermaid is
      // ready — `startOnLoad` would never trigger. Render explicitly instead.
      if (document.querySelector("pre.mermaid")) {
        const mermaidUrl =
          "https://cdn.jsdelivr.net/npm/mermaid@11/dist/mermaid.esm.min.mjs";
        import(/* @vite-ignore */ mermaidUrl)
          .then(async ({ default: mermaid }) => {
            const dark = document.documentElement.dataset.theme === "dark";
            mermaid.initialize({
              startOnLoad: false,
              theme: dark ? "dark" : "default",
            });
            try {
              await mermaid.run({ querySelector: "pre.mermaid" });
            } catch (e) {
              console.error("Mermaid render failed:", e);
            }
          });
      }
    </script>
  </body>
</html>
