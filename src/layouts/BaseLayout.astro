---
// Self-hosted Ubuntu Mono (latin subset) — bundled into _astro, no runtime CDN
// and no render-blocking @import chain. font-display: swap is set by fontsource.
import "@fontsource/ubuntu-mono/latin-400.css";
import "@fontsource/ubuntu-mono/latin-400-italic.css";
import "@fontsource/ubuntu-mono/latin-700.css";
import "@fontsource/ubuntu-mono/latin-700-italic.css";
import "../styles/global.css";
import { ClientRouter } from "astro:transitions";
import BaseHead from "../components/BaseHead.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import Search from "../components/Search.astro";

interface Props {
  title?: string;
  description?: string;
  canonicalPath: string;
  image?: string | null;
  type?: "website" | "article";
  publishedTime?: Date;
  jsonLd?: object | object[];
  feed?: { title: string; href: string };
  noindex?: boolean;
}
const props = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <BaseHead {...props} />
    {/* Apply the theme before paint to avoid a flash. <html> persists across
        View-Transitions navigations, so the choice carries over automatically. */}
    <script is:inline>
      (() => {
        const t = localStorage.getItem("theme") ||
          (matchMedia("(prefers-color-scheme: dark)").matches ? "dark" : "light");
        document.documentElement.dataset.theme = t;
      })();
    </script>
    {/* Client-side navigation so we can show a loader between pages. Interactive
        scripts re-initialize on `astro:page-load` (they're not persisted). */}
    <ClientRouter />
    {/* Umami (cookieless), proxied first-party via /u so blockers don't drop it.
        Production only — no localhost noise. See functions/u/[[path]].js. */}
    {import.meta.env.PROD && (
      <script
        is:inline
        defer
        src="/u/script.js"
        data-website-id="c7d523fd-446c-4fa9-af93-7c096a4310fb"
        data-host-url="https://faizahmed.in/u"
        transition:persist
      ></script>
    )}
  </head>
  <body>
    <a href="#main-content" class="skip-link">Skip to content</a>
    <Header />
    <main id="main-content" class="wrap">
      <slot />
    </main>
    <Footer />
    <Search />

    {/* Route loader — persists across navigations; shown only when a navigation
        takes longer than the delay below, so fast loads never flash it. */}
    <div id="route-loader" class="route-loader" transition:persist hidden>
      <div class="rl-card" role="status" aria-live="polite">
        <span class="rl-spinner" aria-hidden="true"></span>
        <span class="rl-text">Loading…</span>
      </div>
    </div>

    <script>
      // Show the loader only if navigation is slow enough to notice (>150ms),
      // so instant static loads don't get an annoying flash. These document-level
      // listeners are attached once (this module runs once) and survive nav.
      const el = () => document.getElementById("route-loader");
      let timer: number | undefined;
      document.addEventListener("astro:before-preparation", () => {
        timer = window.setTimeout(() => {
          const l = el();
          if (l) l.hidden = false;
        }, 150);
      });
      const hide = () => {
        clearTimeout(timer);
        const l = el();
        if (l) l.hidden = true;
      };
      document.addEventListener("astro:after-swap", hide);
      document.addEventListener("astro:page-load", hide);
    </script>

    <script>
      // Render Mermaid diagrams on every page (initial load + each client-side
      // navigation). The module is imported once and reused. `startOnLoad` can't
      // be used — the import is async and Rocket Loader defers scripts.
      let mermaidMod: Promise<any> | undefined;
      const mermaidUrl =
        "https://cdn.jsdelivr.net/npm/mermaid@11/dist/mermaid.esm.min.mjs";
      document.addEventListener("astro:page-load", async () => {
        if (!document.querySelector("pre.mermaid")) return;
        const dark = document.documentElement.dataset.theme === "dark";
        mermaidMod = mermaidMod || import(/* @vite-ignore */ mermaidUrl);
        try {
          const { default: mermaid } = await mermaidMod;
          mermaid.initialize({ startOnLoad: false, theme: dark ? "dark" : "default" });
          await mermaid.run({ querySelector: "pre.mermaid:not([data-processed])" });
        } catch (e) {
          console.error("Mermaid render failed:", e);
        }
      });
    </script>
  </body>
</html>

<style>
  .route-loader {
    position: fixed;
    inset: 0;
    z-index: 200;
    display: grid;
    place-items: center;
    background: color-mix(in srgb, var(--bg) 72%, transparent);
    backdrop-filter: blur(2px);
  }
  /* `display: grid` above out-specifies the UA [hidden] rule. */
  .route-loader[hidden] { display: none; }
  .rl-card {
    display: flex;
    align-items: center;
    gap: 12px;
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 14px 18px;
    box-shadow: 0 12px 40px rgba(0, 0, 0, 0.18);
    font-family: var(--font);
    color: var(--text-soft);
    font-size: 0.95rem;
  }
  .rl-spinner {
    width: 16px;
    height: 16px;
    border-radius: 50%;
    border: 2px solid var(--border);
    border-top-color: var(--accent);
    animation: rl-spin 0.7s linear infinite;
  }
  @keyframes rl-spin { to { transform: rotate(360deg); } }
  @media (prefers-reduced-motion: reduce) {
    .rl-spinner { animation-duration: 2s; }
  }
</style>
