---
// ⌘K / Ctrl+K command palette. Fetches /search.json once and filters
// client-side over title, tags, series, and an excerpt. Works in dev + prod.
---
<div id="search-modal" class="search-modal" hidden>
  <div class="search-backdrop" data-close></div>
  <div class="search-panel" role="dialog" aria-modal="true" aria-label="Search posts">
    <div class="search-field">
      <span class="search-icon" aria-hidden="true">⌕</span>
      <input
        id="search-input"
        type="search"
        placeholder="Search…"
        autocomplete="off"
        autocapitalize="off"
        spellcheck="false"
        aria-label="Search the site"
      />
      <kbd>esc</kbd>
    </div>
    <ul id="search-results" role="listbox"></ul>
    <p id="search-hint" class="search-hint">Type to search.</p>
  </div>
</div>

<script>
  const modal = document.getElementById("search-modal")!;
  const input = document.getElementById("search-input") as HTMLInputElement;
  const list = document.getElementById("search-results")!;
  const hint = document.getElementById("search-hint")!;

  type Item = {
    title: string; url: string; tags: string[];
    series: string | null; date: string; excerpt: string;
  };

  let data: Item[] | null = null;
  let active = -1;

  async function ensureData() {
    if (data) return;
    try {
      data = await (await fetch("/search.json")).json();
    } catch {
      data = [];
    }
  }

  function score(item: Item, q: string): number {
    const t = item.title.toLowerCase();
    if (t === q) return 100;
    if (t.startsWith(q)) return 80;
    if (t.includes(q)) return 60;
    if ((item.series ?? "").toLowerCase().includes(q)) return 40;
    if (item.tags.some((tag) => tag.toLowerCase().includes(q))) return 35;
    if (item.excerpt.toLowerCase().includes(q)) return 20;
    return 0;
  }

  function render(q: string) {
    active = -1;
    if (!q.trim() || !data) {
      list.innerHTML = "";
      hint.hidden = false;
      hint.textContent = data ? "Type to search." : "Loading…";
      return;
    }
    const needle = q.toLowerCase();
    const hits = data
      .map((item) => ({ item, s: score(item, needle) }))
      .filter((r) => r.s > 0)
      .sort((a, b) => b.s - a.s)
      .slice(0, 8);

    if (hits.length === 0) {
      list.innerHTML = "";
      hint.hidden = false;
      hint.textContent = `No results for “${q}”.`;
      return;
    }
    hint.hidden = true;
    list.innerHTML = hits
      .map(
        ({ item }, i) => `
        <li role="option" data-index="${i}">
          <a href="${item.url}">
            <span class="r-title">${item.title}</span>
            ${item.series ? `<span class="r-series">${item.series}</span>` : ""}
            <span class="r-excerpt">${item.excerpt}</span>
          </a>
        </li>`,
      )
      .join("");
  }

  function setActive(next: number) {
    const items = [...list.querySelectorAll<HTMLLIElement>("li")];
    if (items.length === 0) return;
    active = (next + items.length) % items.length;
    items.forEach((li, i) => li.classList.toggle("active", i === active));
    items[active].scrollIntoView({ block: "nearest" });
  }

  async function open() {
    modal.hidden = false;
    document.body.style.overflow = "hidden";
    await ensureData();
    render(input.value);
    input.focus();
    input.select();
  }
  function close() {
    modal.hidden = true;
    document.body.style.overflow = "";
  }

  document.getElementById("search-open")?.addEventListener("click", open);
  modal.querySelector("[data-close]")?.addEventListener("click", close);
  input.addEventListener("input", () => render(input.value));

  document.addEventListener("keydown", (e) => {
    if ((e.metaKey || e.ctrlKey) && e.key.toLowerCase() === "k") {
      e.preventDefault();
      modal.hidden ? open() : close();
      return;
    }
    if (modal.hidden) return;
    if (e.key === "Escape") close();
    else if (e.key === "ArrowDown") { e.preventDefault(); setActive(active + 1); }
    else if (e.key === "ArrowUp") { e.preventDefault(); setActive(active - 1); }
    else if (e.key === "Enter") {
      const items = [...list.querySelectorAll<HTMLAnchorElement>("li a")];
      const target = active >= 0 ? items[active] : items[0];
      if (target) window.location.href = target.getAttribute("href")!;
    }
  });
</script>

<style>
  .search-modal { position: fixed; inset: 0; z-index: 100; }
  .search-backdrop { position: absolute; inset: 0; background: rgba(0,0,0,0.45); }
  .search-panel {
    position: relative;
    width: min(560px, calc(100vw - 32px));
    margin: 14vh auto 0;
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: 14px;
    box-shadow: 0 16px 50px rgba(0,0,0,0.3);
    overflow: hidden;
  }
  .search-field {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 14px 16px;
    border-bottom: 1px solid var(--border);
  }
  .search-icon { color: var(--text-faint); font-size: 1.1rem; }
  #search-input {
    flex: 1;
    border: none;
    outline: none;
    background: transparent;
    color: var(--text);
    font-family: var(--font);
    font-size: 1rem;
  }
  #search-input::placeholder { color: var(--text-faint); }
  .search-field kbd {
    font-family: var(--font);
    font-size: 0.7rem;
    color: var(--text-faint);
    border: 1px solid var(--border);
    border-radius: 5px;
    padding: 2px 6px;
  }
  #search-results { list-style: none; margin: 0; padding: 6px; max-height: 56vh; overflow-y: auto; }
  .search-hint { color: var(--text-faint); font-size: 0.85rem; padding: 16px; margin: 0; text-align: center; }
</style>

<style is:global>
  /* Result rows are injected via innerHTML, so Astro's scoped attribute is not
     applied to them — these rules must be global to take effect. */
  #search-results li { border-radius: 9px; }
  #search-results li + li { margin-top: 2px; }
  #search-results li a {
    display: block;
    padding: 10px 12px;
    border-radius: 9px;
    color: var(--text);
    text-decoration: none;
  }
  #search-results li a:hover,
  #search-results li.active a { background: var(--bg-soft); }
  #search-results .r-title { display: block; font-weight: 700; color: var(--text); line-height: 1.4; }
  #search-results .r-series {
    display: inline-block;
    font-size: 0.72rem;
    color: var(--accent);
    margin-top: 3px;
  }
  #search-results .r-excerpt {
    display: block;
    color: var(--text-faint);
    font-size: 0.82rem;
    margin-top: 3px;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
</style>
