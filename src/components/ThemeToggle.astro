---
// Auto (system) by default, with a manual toggle that persists the choice.
---
<button id="theme-toggle" type="button" aria-label="Toggle color theme">
  <span class="icon-sun" aria-hidden="true">☀</span>
  <span class="icon-moon" aria-hidden="true">☾</span>
</button>

<script>
  // Theme is applied pre-paint by the inline script in BaseLayout's <head>.
  // Here we just (re)bind the toggle button on every page load — with View
  // Transitions the header is swapped, so each navigation gets a fresh button.
  document.addEventListener("astro:page-load", () => {
    const btn = document.getElementById("theme-toggle");
    if (!btn || btn.dataset.bound) return;
    btn.dataset.bound = "1";
    btn.addEventListener("click", () => {
      const root = document.documentElement;
      const next = root.dataset.theme === "dark" ? "light" : "dark";
      root.dataset.theme = next;
      localStorage.setItem("theme", next);
    });
  });
</script>

<style>
  #theme-toggle {
    background: none;
    border: 1px solid var(--border);
    border-radius: 7px;
    color: var(--text-soft);
    cursor: pointer;
    width: 34px;
    height: 34px;
    font-size: 15px;
    line-height: 1;
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }
  #theme-toggle:hover { color: var(--text); border-color: var(--text-faint); }
  :root[data-theme="dark"] .icon-sun { display: none; }
  :root[data-theme="light"] .icon-moon,
  :root:not([data-theme="dark"]) .icon-moon { display: none; }
</style>
