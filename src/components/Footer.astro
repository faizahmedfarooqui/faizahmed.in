<style>
  .site-footer {
    border-top: 1px solid var(--border);
    margin-top: 4rem;
    padding: 1.6rem 0;
    color: var(--text-faint);
    font-size: 0.9rem;
  }
  .site-footer .wrap {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 12px;
    flex-wrap: wrap;
  }
  .site-footer nav { display: flex; gap: 16px; }
  .site-footer a { color: var(--text-soft); }
