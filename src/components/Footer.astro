const year = new Date().getFullYear();
---
<footer class="site-footer">
  <div class="wrap">
    <span>© {year} Faiz Ahmed Farooqui</span>
    <nav>
      <a href="/about">About</a>
      <a href="/uses">Uses</a>
      <a href="/now">Now</a>
