---
// Click-to-play YouTube facade. Shows only a thumbnail until the visitor clicks;
// then it swaps in the privacy-friendly youtube-nocookie player. No YouTube
// script or tracking loads on page view.
interface Props { id: string; title: string; }
const { id, title } = Astro.props;
const thumb = `https://i.ytimg.com/vi/${id}/hqdefault.jpg`;
---
<div class="lyt" data-id={id}>
  <button class="lyt-btn" type="button" aria-label={`Play video: ${title}`}>
    <img src={thumb} alt="" loading="lazy" width="480" height="360" />
    <span class="lyt-play" aria-hidden="true">▶</span>
  </button>
</div>

<script>
  // Re-bind on every page load (initial + client-side navigation), since the
  // /bolt content is swapped by View Transitions. `data-lyt-bound` guards against
  // double-binding the same element.
  function bindLiteYouTube() {
    document.querySelectorAll<HTMLElement>(".lyt").forEach((el) => {
      if (el.dataset.lytBound) return;
      el.dataset.lytBound = "1";
      el.querySelector(".lyt-btn")?.addEventListener("click", () => {
        const id = el.dataset.id;
        const iframe = document.createElement("iframe");
        iframe.src = `https://www.youtube-nocookie.com/embed/${id}?autoplay=1&rel=0`;
        iframe.title = "YouTube video player";
        iframe.allow =
          "accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share";
        iframe.allowFullscreen = true;
        iframe.loading = "lazy";
        iframe.style.cssText = "position:absolute;inset:0;width:100%;height:100%;border:0;";
        el.innerHTML = "";
        el.appendChild(iframe);
      });
    });
  }
  document.addEventListener("astro:page-load", bindLiteYouTube);
</script>

<style>
  .lyt {
    position: relative;
    aspect-ratio: 16 / 9;
    border-radius: 12px;
    overflow: hidden;
    background: #000;
    border: 1px solid var(--border);
  }
  .lyt-btn {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    padding: 0;
    border: none;
    cursor: pointer;
    background: none;
  }
  .lyt-btn img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .lyt-play {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 62px;
    height: 62px;
    border-radius: 50%;
    background: rgba(0, 0, 0, 0.6);
    color: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 20px;
    padding-left: 4px;
  }
  .lyt-btn:hover .lyt-play { background: var(--accent); }
</style>
