---
import { Image } from "astro:assets";
import type { Post } from "../lib/posts";
import { postSlug, readMinutes, formatDate, excerpt } from "../lib/posts";

interface Props { post: Post; featured?: boolean; }
const { post, featured = false } = Astro.props;
const href = `/${postSlug(post)}`;
const body = post.body ?? "";
const mins = readMinutes(body);
const cover = post.data.cover;
const blurb = excerpt(body, featured ? 240 : 130);
---
<article class:list={["post-card", { featured }]}>
  {cover && (
    <div class="pc-media">
      <Image src={cover} alt={post.data.title} width={featured ? 1000 : 640} loading="lazy" />
    </div>
  )}
  <div class="pc-body">
    {post.data.series && (
      <a class="pc-series" href={`/series/${post.data.series}`}>{post.data.series}</a>
    )}
    <h2 class="pc-title">
      <a class="pc-titlelink" href={href}>{post.data.title}</a>
    </h2>
    <p class="pc-excerpt">{blurb}</p>
    <p class="pc-meta">
      <time datetime={post.data.datePublished.toISOString()}>
        {formatDate(post.data.datePublished)}
      </time>
      <span aria-hidden="true">·</span>
      <span>{mins} min read</span>
    </p>
  </div>
</article>

<style>
  .post-card {
    position: relative;
    display: flex;
    flex-direction: column;
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: 14px;
    overflow: hidden;
    transition: transform 0.15s ease, box-shadow 0.15s ease, border-color 0.15s ease;
  }
  .post-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 14px 36px rgba(0, 0, 0, 0.12);
    border-color: var(--accent);
  }

  .pc-media {
    aspect-ratio: 16 / 9;
    overflow: hidden;
    background: var(--bg-soft);
  }
  .pc-media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.3s ease;
  }
  .post-card:hover .pc-media img { transform: scale(1.04); }

  .pc-body {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    padding: 1.1rem 1.2rem 1.3rem;
    flex: 1;
  }
  .pc-series {
    align-self: flex-start;
    position: relative;
    z-index: 1; /* sit above the title's full-card overlay */
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--accent);
    background: var(--accent-soft);
    padding: 2px 8px;
    border-radius: 999px;
  }
  .pc-series:hover { text-decoration: none; filter: brightness(0.97); }

  .pc-title { margin: 0; font-size: 1.18rem; line-height: 1.35; }
  .pc-titlelink { color: var(--text); }
  .pc-titlelink:hover { color: var(--accent); text-decoration: none; }
  /* The title link covers the whole card, so clicking anywhere opens the post
     (the series badge sits above it via z-index). */
  .pc-titlelink::after { content: ""; position: absolute; inset: 0; }

  .pc-excerpt {
    margin: 0;
    color: var(--text-soft);
    font-size: 0.9rem;
    line-height: 1.55;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .pc-meta {
    margin: auto 0 0;
    padding-top: 0.3rem;
    color: var(--text-faint);
    font-size: 0.82rem;
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
  }

  /* Featured: wide hero card, image beside the text on larger screens. */
  .post-card.featured { grid-column: 1 / -1; }
  @media (min-width: 720px) {
    .post-card.featured { flex-direction: row; }
    .post-card.featured .pc-media { flex: 0 0 55%; aspect-ratio: auto; }
    .post-card.featured .pc-body { padding: 1.8rem 2rem; }
    .post-card.featured .pc-title { font-size: 1.7rem; }
    .post-card.featured .pc-excerpt { -webkit-line-clamp: 4; font-size: 0.95rem; }
  }
</style>
