---
import { GA_MEASUREMENT_ID } from "../consts";
// GA4 wired directly (no Tag Manager container). Only loads in production builds.
const enabled = import.meta.env.PROD && GA_MEASUREMENT_ID;
---

{enabled && (
  <>
    <script
      is:inline
      async
      src={`https://www.googletagmanager.com/gtag/js?id=${GA_MEASUREMENT_ID}`}
    ></script>
    <script is:inline define:vars={{ GA_MEASUREMENT_ID }}>
      window.dataLayer = window.dataLayer || [];
      function gtag() { dataLayer.push(arguments); }
      gtag("js", new Date());
      gtag("config", GA_MEASUREMENT_ID);
    </script>
  </>
)}
