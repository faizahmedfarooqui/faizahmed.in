---
import { SITE_TITLE, SERIES } from "../consts";
import { getPosts } from "../lib/posts";
import ThemeToggle from "./ThemeToggle.astro";

// Build the dropdown from every series that actually has posts, so new series
// show up automatically. Curated title/description come from SERIES; anything
// uncurated falls back to a humanized slug + post count. Sorted by post count.
const counts = new Map<string, number>();
for (const p of await getPosts()) {
  const s = p.data.series;
  if (s) counts.set(s, (counts.get(s) ?? 0) + 1);
}
const humanize = (slug: string) =>
  slug.replace(/[-_]/g, " ").replace(/\b\w/g, (c) => c.toUpperCase());
const seriesList = [...counts.entries()]
  .sort((a, b) => b[1] - a[1])
  .map(([slug, count]) => {
    const meta = SERIES.find((s) => s.slug === slug);
    return {
      slug,
      title: meta?.title ?? humanize(slug),
      description:
        meta?.description ?? `${count} ${count === 1 ? "post" : "posts"}`,
    };
  });
---
<header class="site-header">
  <div class="wrap bar">
    <a class="brand" href="/">
      <span>{SITE_TITLE}</span>
    </a>

    <nav class="nav-group" aria-label="Primary">
    <a class="nav-link" href="/about">About</a>

    <div class="series-dd">
      <button id="series-trigger" class="nav-link" type="button" aria-haspopup="true" aria-expanded="false" aria-controls="series-menu">Series <span aria-hidden="true">▾</span></button>
      <div id="series-menu" class="series-menu" role="menu" hidden>
        {seriesList.map((s) => (
          <a href={`/series/${s.slug}`} role="menuitem">
            <span class="s-title">{s.title}</span>
            <span class="s-desc">{s.description}</span>
          </a>
        ))}
      </div>
    </div>

    <a class="nav-link" href="/tags">Tags</a>
    </nav>

    <div class="actions">
      <button id="search-open" type="button" aria-label="Search (Ctrl/Cmd + K)">⌘K</button>
      <ThemeToggle />
    </div>
  </div>
</header>

<style>
  .site-header {
    border-bottom: 1px solid var(--border);
    background: var(--bg);
    position: sticky;
    top: 0;
    z-index: 20;
  }
  .bar {
    display: flex;
    align-items: center;
    gap: 16px;
    height: 56px;
  }
  .brand {
    display: flex;
    align-items: center;
    gap: 9px;
    color: var(--text);
    font-weight: 700;
    white-space: nowrap;
  }
  .brand:hover { text-decoration: none; }
  .nav-group { display: flex; align-items: center; gap: 16px; }
  .nav-link {
    color: var(--text-soft);
    font-size: 0.9rem;
    white-space: nowrap;
    background: none;
    border: none;
    cursor: pointer;
    font-family: var(--font);
    padding: 0;
  }
  .nav-link:hover { color: var(--accent); text-decoration: none; }
  .series-dd { position: relative; }
  .series-menu {
    position: absolute;
    top: calc(100% + 10px);
    left: 0;
    /* Lay series out top-to-bottom, 3 per column, then wrap into new columns. */
    display: grid;
    grid-template-rows: repeat(3, auto);
    grid-auto-flow: column;
    grid-auto-columns: 300px;
    gap: 2px;
    /* Never wider than the viewport; scroll horizontally if columns overflow. */
    max-width: calc(100vw - 24px);
    overflow-x: auto;
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: 12px;
    box-shadow: 0 12px 40px rgba(0,0,0,0.18);
    padding: 6px;
    z-index: 30;
  }
  /* `display: grid` above out-specifies the UA [hidden] rule, so the closed
     state must be declared explicitly or the menu stays open. */
  .series-menu[hidden] { display: none; }
  .series-menu a {
    display: block;
    padding: 10px 12px;
    border-radius: 9px;
    color: var(--text);
  }
  .series-menu a:hover { background: var(--bg-soft); text-decoration: none; }
  .s-title { display: block; font-weight: 700; font-size: 0.92rem; }
  .s-desc { display: block; color: var(--text-faint); font-size: 0.8rem; margin-top: 3px; line-height: 1.5; }
  .actions { display: flex; align-items: center; gap: 8px; margin-left: auto; }
  #search-open {
    background: var(--bg-soft);
    border: 1px solid var(--border);
    border-radius: 7px;
    color: var(--text-soft);
    cursor: pointer;
    height: 34px;
    padding: 0 10px;
    font-family: var(--font);
    font-size: 0.85rem;
  }
  #search-open:hover { color: var(--text); }
  @media (max-width: 640px) {
    /* Two rows: brand + action buttons on top, nav links on their own row below.
       This avoids the buttons wrapping to a second line with a big empty gap. */
    /* padding-block only — leave the .wrap left/right gutter intact (using
       `padding: 10px 0` here would zero out the horizontal padding). */
    .bar { flex-wrap: wrap; height: auto; padding-block: 10px; row-gap: 10px; column-gap: 12px; }
    .brand { order: 1; font-size: 1rem; }
    .actions { order: 2; }
    .nav-group { order: 3; flex-basis: 100%; gap: 20px; }
    /* Anchor the menu to the header (full width with side gutters) rather than the
       Series button — otherwise it overflows the viewport depending on where the
       button lands in the wrapped header. Single column, scroll vertically. */
    .series-dd { position: static; }
    .series-menu {
      grid-auto-flow: row;
      grid-template-rows: none;
      grid-auto-columns: auto;
      left: 12px;
      right: 12px;
      width: auto;
      max-width: none;
      max-height: 70vh;
      overflow-x: hidden;
      overflow-y: auto;
    }
  }
</style>

<script>
  const trigger = document.getElementById("series-trigger");
  const menu = document.getElementById("series-menu");
  if (trigger && menu) {
    const setOpen = (open: boolean) => {
      menu.hidden = !open;
      trigger.setAttribute("aria-expanded", String(open));
    };
    trigger.addEventListener("click", (e) => {
      e.stopPropagation();
      // Toggle: `hidden` is typed `string | boolean`, so coerce to a boolean.
      setOpen(Boolean(menu.hidden));
    });
    document.addEventListener("click", (e) => {
      if (!menu.hidden && !menu.contains(e.target as Node) && e.target !== trigger) {
        setOpen(false);
      }
    });
    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape") setOpen(false);
    });
  }
</script>
