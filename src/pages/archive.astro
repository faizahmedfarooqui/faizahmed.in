---
import BaseLayout from "../layouts/BaseLayout.astro";
import PostCard from "../components/PostCard.astro";
import { getPosts } from "../lib/posts";

const posts = await getPosts();
const byYear = new Map<number, typeof posts>();
for (const p of posts) {
  const y = p.data.datePublished.getFullYear();
  if (!byYear.has(y)) byYear.set(y, []);
  byYear.get(y)!.push(p);
}
const years = [...byYear.keys()].sort((a, b) => b - a);
---
<BaseLayout title="Archive" description="Every post, by year." canonicalPath="/archive">
  <header class="arch-head">
    <h1>Archive</h1>
    <p class="count">{posts.length} posts</p>
  </header>

  {years.map((year) => (
    <section class="arch-year">
      <h2 class="year-label">
        <span>{year}</span>
        <span class="year-n">{byYear.get(year)!.length}</span>
      </h2>
      <div class="feed">
        {byYear.get(year)!.map((post) => <PostCard post={post} />)}
      </div>
    </section>
  ))}
</BaseLayout>

<style>
  .arch-head { margin: 2.2rem 0 0.5rem; }
  .arch-head h1 { margin: 0; }
  .arch-head .count { color: var(--text-faint); margin: 0.3rem 0 0; font-size: 0.9rem; }
  .arch-year { margin-top: 2.5rem; }
  .year-label {
    display: flex;
    align-items: baseline;
    gap: 10px;
    font-size: 1.15rem;
    color: var(--text-faint);
    border-bottom: 1px solid var(--border);
    padding-bottom: 0.4rem;
    margin-bottom: 1.3rem;
  }
  .year-n { font-size: 0.8rem; }
</style>
