---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PostCard from "../../components/PostCard.astro";
import { getPosts } from "../../lib/posts";

export async function getStaticPaths() {
  const posts = await getPosts();
  const tags = new Set<string>();
  for (const p of posts) for (const t of p.data.tags) tags.add(t);

  return [...tags].map((tag) => ({
    params: { tag },
    props: { posts: posts.filter((p) => p.data.tags.includes(tag)) },
  }));
}

const { tag } = Astro.params;
const { posts } = Astro.props;
---
<BaseLayout
  title={`#${tag}`}
  description={`Posts tagged ${tag}.`}
  canonicalPath={`/tag/${tag}`}
  feed={{ title: `#${tag} · feed`, href: `/tag/${tag}/rss.xml` }}
>
  <h1 class="page-title">#{tag}</h1>
  <p class="count">
    {posts.length} {posts.length === 1 ? "post" : "posts"}
    <a class="feed-link" href={`/tag/${tag}/rss.xml`}>RSS</a>
  </p>
  <div class="feed">
    {posts.map((post) => <PostCard post={post} />)}
  </div>
</BaseLayout>

<style>
  .page-title { margin: 2.2rem 0 0.2rem; }
  .count { color: var(--text-faint); margin: 0 0 1rem; font-size: 0.9rem; }
  .feed-link { margin-left: 10px; }
</style>
