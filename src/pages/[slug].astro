---
import { Image, getImage } from "astro:assets";
import { render } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import AuthorCard from "../components/AuthorCard.astro";
import { getPosts, postSlug, readMinutes, formatDate, excerpt, type Post } from "../lib/posts";
import { CANONICAL_ORIGIN, AUTHOR, SERIES } from "../consts";

export async function getStaticPaths() {
  const posts = await getPosts(); // newest first
  const lite = (p: Post | undefined) =>
    p ? { slug: postSlug(p), title: p.data.title } : null;

  return posts.map((post) => {
    // Position within the series (chronological) + prev/next links.
    let seriesNav = null;
    if (post.data.series) {
      const inSeries = posts
        .filter((p) => p.data.series === post.data.series)
        .sort(
          (a, b) =>
            a.data.datePublished.valueOf() - b.data.datePublished.valueOf(),
        );
      const i = inSeries.findIndex((p) => p.id === post.id);
      seriesNav = {
        slug: post.data.series,
        title:
          SERIES.find((s) => s.slug === post.data.series)?.title ??
          post.data.series,
        index: i,
        total: inSeries.length,
        prev: lite(inSeries[i - 1]),
        next: lite(inSeries[i + 1]),
      };
    }

    // Related: most shared tags, then most recent. Exclude same-series posts
    // (already covered by the series nav) so the two sections don't overlap.
    const related = posts
      .filter(
        (p) =>
          p.id !== post.id &&
          !(post.data.series && p.data.series === post.data.series),
      )
      .map((p) => ({
        p,
        shared: p.data.tags.filter((t) => post.data.tags.includes(t)).length,
      }))
      .filter((x) => x.shared > 0)
      .sort(
        (a, b) =>
          b.shared - a.shared ||
          b.p.data.datePublished.valueOf() - a.p.data.datePublished.valueOf(),
      )
      .slice(0, 3)
      .map((x) => ({ slug: postSlug(x.p), title: x.p.data.title }));

    return {
      params: { slug: postSlug(post) },
      props: { post, seriesNav, related },
    };
  });
}

const { post, seriesNav, related } = Astro.props;
const { Content, headings } = await render(post);
const toc = headings.filter((h) => h.depth >= 2 && h.depth <= 3);
const body = post.body ?? "";
const mins = readMinutes(body);
const desc = post.data.description ?? excerpt(body, 160);
// Social-card image: a 1200px-wide JPEG derivative on the canonical host —
// not the multi-MB original (which then no longer needs emitting at all).
const ogCover = post.data.cover
  ? await getImage({ src: post.data.cover, width: 1200, format: "jpg" })
  : undefined;
const ogImage = ogCover
  ? new URL(ogCover.src, CANONICAL_ORIGIN).href
  : undefined;

const canonicalUrl = new URL(`/${postSlug(post)}`, CANONICAL_ORIGIN).href;
const published = post.data.datePublished.toISOString();
const blogPosting = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  headline: post.data.title,
  description: desc,
  datePublished: published,
  dateModified: published,
  author: { "@type": "Person", name: AUTHOR.name, url: `${CANONICAL_ORIGIN}/` },
  publisher: { "@type": "Person", name: AUTHOR.name },
  mainEntityOfPage: canonicalUrl,
  url: canonicalUrl,
  ...(ogImage ? { image: ogImage } : {}),
  ...(post.data.tags.length ? { keywords: post.data.tags.join(", ") } : {}),
};
const breadcrumb = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Home", item: `${CANONICAL_ORIGIN}/` },
    ...(seriesNav
      ? [{
          "@type": "ListItem",
          position: 2,
          name: seriesNav.title,
          item: `${CANONICAL_ORIGIN}/series/${seriesNav.slug}`,
        }]
      : []),
    {
      "@type": "ListItem",
      position: seriesNav ? 3 : 2,
      name: post.data.title,
      item: canonicalUrl,
    },
  ],
};
---
<BaseLayout
  title={post.data.title}
  description={desc}
  canonicalPath={`/${postSlug(post)}`}
  image={ogImage}
  type="article"
  publishedTime={post.data.datePublished}
  jsonLd={[blogPosting, breadcrumb]}
>
  <div class="post-wrap">
  <div class="post-main">
  <article class="post" data-pagefind-body>
    {post.data.cover && (
      <Image class="cover" src={post.data.cover} alt={post.data.title} priority />
    )}
    <h1 data-pagefind-meta="title">{post.data.title}</h1>
    <p class="post-meta">
      <time datetime={post.data.datePublished.toISOString()}>
        {formatDate(post.data.datePublished)}
      </time>
      <span aria-hidden="true">·</span>
      <span>{mins} min read</span>
      {post.data.series && (
        <>
          <span aria-hidden="true">·</span>
          <a href={`/series/${post.data.series}`}>{post.data.series}</a>
        </>
      )}
    </p>

    {post.data.tags.length > 0 && (
      <p class="tags">
        {post.data.tags.map((t) => <a href={`/tag/${t}`}>#{t}</a>)}
      </p>
    )}

    <div class="prose">
      <Content />
    </div>
  </article>

  {seriesNav && (
    <nav class="series-nav" aria-label="Series navigation">
      <p class="sn-meta">
        Part {seriesNav.index + 1} of {seriesNav.total} in{" "}
        <a href={`/series/${seriesNav.slug}`}>{seriesNav.title}</a>
      </p>
      <div class="sn-links">
        {seriesNav.prev ? (
          <a class="sn-card sn-prev" href={`/${seriesNav.prev.slug}`}>
            <span class="sn-dir">← Previous</span>
            <span class="sn-title">{seriesNav.prev.title}</span>
          </a>
        ) : <span />}
        {seriesNav.next ? (
          <a class="sn-card sn-next" href={`/${seriesNav.next.slug}`}>
            <span class="sn-dir">Next →</span>
            <span class="sn-title">{seriesNav.next.title}</span>
          </a>
        ) : <span />}
      </div>
    </nav>
  )}

  {related.length > 0 && (
    <section class="related" aria-label="Related posts">
      <h2>Related posts</h2>
      <ul>
        {related.map((r) => (
          <li><a href={`/${r.slug}`}>{r.title}</a></li>
        ))}
      </ul>
    </section>
  )}

  <AuthorCard />
  </div>

  {toc.length > 0 && (
    <aside class="post-toc" aria-label="Table of contents">
      <p class="toc-title">On this page</p>
      <nav>
        <ul>
          {toc.map((h) => (
            <li class:list={[`toc-d${h.depth}`]}>
              <a href={`#${h.slug}`}>{h.text}</a>
            </li>
          ))}
        </ul>
      </nav>
    </aside>
  )}
  </div>
</BaseLayout>

<style>
  /* Reading column + sticky table-of-contents rail on the right. The pair is
     centered within the wide shell; the TOC stays put while the post scrolls. */
  .post-wrap {
    display: grid;
    grid-template-columns: minmax(0, var(--reading)) 240px;
    gap: 48px;
    justify-content: center;
    align-items: start;
  }
  .post-main { min-width: 0; }
  .post { padding-top: 1.8rem; }
  .cover { width: 100%; border-radius: 12px; margin-bottom: 1.5rem; }
  .post h1 { margin: 0 0 0.5rem; }
  .post-meta { color: var(--text-faint); font-size: 0.9rem; display: flex; gap: 8px; flex-wrap: wrap; margin: 0 0 0.6rem; }
  .tags { display: flex; gap: 12px; flex-wrap: wrap; font-size: 0.88rem; margin: 0 0 1.5rem; }
  .tags a { color: var(--text-soft); }
  .prose { margin-top: 1.5rem; }

  .post-toc {
    position: sticky;
    top: 80px;
    align-self: start;
    max-height: calc(100vh - 100px);
    overflow-y: auto;
    padding-top: 1.8rem;
    font-size: 0.85rem;
  }
  .toc-title {
    margin: 0 0 0.6rem;
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--text-faint);
  }
  .post-toc nav ul { list-style: none; margin: 0; padding: 0; }
  .post-toc li { margin: 0; }
  .post-toc a {
    display: block;
    padding: 4px 0 4px 12px;
    border-left: 2px solid var(--border);
    color: var(--text-faint);
    line-height: 1.4;
  }
  .post-toc a:hover { color: var(--text); text-decoration: none; }
  .post-toc a.active { color: var(--accent); border-left-color: var(--accent); }
  .post-toc .toc-d3 a { padding-left: 24px; font-size: 0.95em; }

  /* No room for the rail on narrower screens — drop to a single column. */
  @media (max-width: 1024px) {
    .post-wrap { grid-template-columns: minmax(0, 1fr); max-width: var(--reading); margin: 0 auto; }
    .post-toc { display: none; }
  }

  /* Series navigation (prev/next within the series). */
  .series-nav { margin: 2.5rem 0 1rem; }
  .sn-meta { margin: 0 0 0.7rem; font-size: 0.85rem; color: var(--text-faint); }
  .sn-links { display: flex; gap: 14px; }
  .sn-card {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 4px;
    padding: 0.8rem 1rem;
    border: 1px solid var(--border);
    border-radius: 10px;
    color: var(--text);
    transition: border-color 0.15s ease;
  }
  .sn-card:hover { border-color: var(--accent); text-decoration: none; }
  .sn-next { text-align: right; }
  .sn-dir { font-size: 0.78rem; color: var(--accent); }
  .sn-title { font-weight: 700; line-height: 1.35; }

  /* Related posts. */
  .related { margin: 2rem 0 1rem; padding-top: 1.5rem; border-top: 1px solid var(--border); }
  .related h2 { font-size: 1.1rem; margin: 0 0 0.6rem; }
  .related ul { list-style: none; margin: 0; padding: 0; }
  .related li { padding: 0.35rem 0; }
  .related a { color: var(--text); }
  .related a:hover { color: var(--accent); }

  @media (max-width: 520px) {
    .sn-links { flex-direction: column; }
    .sn-next { text-align: left; }
  }
</style>

<script>
  // Runs on initial load AND after each View-Transitions navigation, since the
  // post content (code blocks, TOC) gets swapped. Guards keep re-runs idempotent.
  document.addEventListener("astro:page-load", () => {
  // Enhance code blocks with a terminal-style header (language + copy button).
  document.querySelectorAll<HTMLPreElement>("pre.astro-code").forEach((pre) => {
    if (pre.closest(".code-block")) return;
    let lang = pre.getAttribute("data-language") || "code";
    if (lang === "plaintext" || lang === "text") lang = "text";

    const block = document.createElement("figure");
    block.className = "code-block";
    const head = document.createElement("figcaption");
    head.className = "code-head";
    const label = document.createElement("span");
    label.className = "code-lang";
    label.textContent = lang;
    const copy = document.createElement("button");
    copy.type = "button";
    copy.className = "code-copy";
    copy.textContent = "Copy";
    head.append(label, copy);

    pre.parentNode?.insertBefore(block, pre);
    block.append(head, pre);

    copy.addEventListener("click", async () => {
      try {
        await navigator.clipboard.writeText(pre.innerText);
        copy.textContent = "Copied";
        copy.classList.add("ok");
        setTimeout(() => {
          copy.textContent = "Copy";
          copy.classList.remove("ok");
        }, 1600);
      } catch {
        /* clipboard unavailable */
      }
    });
  });

  // Scroll-spy: highlight the current section in the table of contents.
  const tocLinks = [...document.querySelectorAll<HTMLAnchorElement>(".post-toc a")];
  if (tocLinks.length) {
    const byId = new Map(
      tocLinks.map((a) => [decodeURIComponent(a.hash.slice(1)), a]),
    );
    const seen = [...document.querySelectorAll<HTMLElement>(".prose h2, .prose h3")]
      .filter((h) => byId.has(h.id));
    const observer = new IntersectionObserver(
      (entries) => {
        for (const e of entries) {
          if (!e.isIntersecting) continue;
          tocLinks.forEach((l) => l.classList.remove("active"));
          byId.get((e.target as HTMLElement).id)?.classList.add("active");
        }
      },
      { rootMargin: "-80px 0px -70% 0px" },
    );
    seen.forEach((h) => observer.observe(h));
  }
  });
</script>
