---
import BaseLayout from "../layouts/BaseLayout.astro";
import PostCard from "../components/PostCard.astro";
import RepoCard from "../components/RepoCard.astro";
import { getPosts } from "../lib/posts";
import { getFeaturedRepos } from "../lib/github";
import { AUTHOR, EXPERIENCE, PERSON_JSONLD, WEBSITE_JSONLD } from "../consts";

// Served from faizahmed.in (blog.faizahmed.in 301-redirects here).
// Short profile hero, then the latest-articles feed. Full profile lives at /about.
const posts = await getPosts();
const latest = posts.slice(0, 4);
const repos = await getFeaturedRepos();
---
<BaseLayout canonicalPath="/" jsonLd={[PERSON_JSONLD, WEBSITE_JSONLD]}>
  <section class="hero">
    <div class="hero-main">
      <p class="kicker">Principal Backend Engineer · Bangalore, India</p>
      <h1>{AUTHOR.name}</h1>
      <p class="lede">
        I design and scale cloud-native, multi-tenant systems across fintech,
        healthcare, and SaaS — secure payments, real-time platforms, and backend
        architecture on AWS and OpenStack. I write about the engineering behind it.
      </p>
      <p class="hero-links">
        <a href="/about">About me →</a>
        {AUTHOR.links.map((l) => (
          <a href={l.url} rel="me noopener" target="_blank" download={l.download}>{l.label}</a>
        ))}
      </p>
    </div>

    <aside class="hero-work">
      <h2>Where I work</h2>
      <ul class="xp">
        {EXPERIENCE.map((e) => (
          <li>
            <span class="xp-when">{e.current ? "Now" : "Previously"}</span>
            <span class="xp-role">{e.role}</span>
            <span class="xp-co">
              {e.url ? (
                <a href={e.url} target="_blank" rel="noopener">{e.company}</a>
              ) : (
                e.company
              )}
              <span class="xp-period">· {e.period}</span>
            </span>
          </li>
        ))}
      </ul>
    </aside>
  </section>

  <section class="featured">
    <div class="col">
      <h2>Featured work</h2>
      {repos.map((repo) => <RepoCard repo={repo} />)}
    </div>
    <div class="col">
      <h2>Bolt.SH</h2>
      <p class="bolt-blurb">
        An <a href="https://www.openstack.org" target="_blank" rel="noopener">OpenStack</a>-powered
        IaaS data center I designed and built at GeekyAnts — VM orchestration,
        virtual networking, and load balancing that let teams self-serve infra.
      </p>
      <a class="bolt-more" href="/bolt">Watch the walkthrough series →</a>
    </div>
  </section>

  <h2 class="feed-heading">Latest articles</h2>
  <div class="feed">
    {latest.map((post, i) => <PostCard post={post} featured={i === 0} />)}
  </div>
  <p class="feed-more">
    <a href="/archive">View all {posts.length} posts →</a>
  </p>
</BaseLayout>

<style>
  /* Hero: intro on the left, "Where I work" rail on the right. */
  .hero {
    display: grid;
    grid-template-columns: 1.5fr 1fr;
    gap: 48px;
    align-items: start;
    padding: 2.8rem 0 1.8rem;
    border-bottom: 1px solid var(--border);
  }
  .kicker { color: var(--text-faint); font-size: 0.85rem; margin: 0 0 0.4rem; }
  .hero h1 { margin: 0 0 0.8rem; font-size: 2.1rem; }
  .lede { color: var(--text-soft); max-width: 60ch; margin: 0 0 1.2rem; }
  .hero-links { display: flex; gap: 18px; flex-wrap: wrap; margin: 0; font-size: 0.92rem; }
  .hero-work h2 { margin: 0 0 0.6rem; font-size: 1.05rem; }

  .xp { list-style: none; padding: 0; margin: 0; }
  .xp li { padding: 0.6rem 0; border-bottom: 1px solid var(--border); }
  .xp li:first-child { padding-top: 0; }
  .xp li:last-child { border-bottom: none; }
  .xp-when {
    display: inline-block;
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--accent);
    margin-bottom: 2px;
  }
  .xp-role { display: block; font-weight: 700; }
  .xp-co { display: block; color: var(--text-soft); font-size: 0.9rem; }
  .xp-period { color: var(--text-faint); }

  .featured {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 28px;
    padding: 2rem 0 0.5rem;
  }
  .featured h2 { margin: 0 0 1rem; font-size: 1.25rem; }

  .bolt-blurb { color: var(--text-soft); font-size: 0.92rem; margin: 0 0 1rem; }
  .bolt-more { display: inline-block; font-size: 0.92rem; }

  .feed-heading { margin-top: 2.2rem; }
  .feed-more { margin: 0 0 2.5rem; font-size: 0.95rem; }

  @media (max-width: 820px) {
    .hero { grid-template-columns: 1fr; gap: 1.8rem; }
  }
  @media (max-width: 640px) {
    .featured { grid-template-columns: 1fr; gap: 1.5rem; }
  }
</style>
