---
import BaseLayout from "../layouts/BaseLayout.astro";
import RepoCard from "../components/RepoCard.astro";
import TechLink from "../components/TechLink.astro";
import { getFeaturedRepos } from "../lib/github";
import { getTags } from "../lib/posts";
import { AUTHOR, yearsOfExperience, PERSON_JSONLD, COMPETENCIES } from "../consts";

const exp = yearsOfExperience();
const repos = await getFeaturedRepos();
const tags = new Set(await getTags());
---
<BaseLayout
  title="About"
  description={`Principal Backend Engineer with ${exp}+ years of experience designing and scaling cloud-native, multi-tenant systems in fintech, healthcare, and SaaS.`}
  canonicalPath="/about"
  jsonLd={PERSON_JSONLD}
>
  <article class="about">
    <header class="about-head">
      <p class="kicker">Principal Backend Engineer · Bangalore, India</p>
      <h1>{AUTHOR.name}</h1>
      <p class="links">
        {AUTHOR.links.map((l) => (
          <a href={l.url} rel="me noopener" target="_blank" download={l.download}>{l.label}</a>
        ))}
      </p>
    </header>

    <div class="about-grid">
      <div class="main">
        <section>
          <h2>Summary</h2>
          <p>
            Principal Backend Engineer with {exp}+ years of experience designing
            and scaling cloud-native, multi-tenant systems in fintech,
            healthcare, and SaaS. I work on secure digital payments, real-time
            data platforms, and backend architecture on
            <TechLink label="AWS" tag="aws" tags={tags} /> and
            <TechLink label="OpenStack" tag="openstack" tags={tags} />,
            with a track record of building regulatory-compliant solutions
            aligned with HIPAA, PCI DSS, COPPA, and GDPR. Along the way I've cut
            cloud costs by up to 60%, delivered production platforms for 500K+
            users, and led teams of 6+ engineers.
          </p>
        </section>

        <section>
          <h2>Experience</h2>

          <div class="role">
            <h3>Talendy Holdings: Lead Software Engineer</h3>
            <p class="when">Bengaluru · June 2026 – Present</p>
            <p>Technical leadership and strategy, development and quality, modelling and process.</p>
          </div>

          <div class="role">
            <h3>GeekyAnts: Principal Engineer / Architect</h3>
            <p class="when">Bengaluru · September 2015 – May 2026</p>
            <ul>
              <li>
                <strong>Common Wallet Platform (Fintech)</strong>: Architected a
                white-label digital wallet for US banks, similar to Apple Pay.
                Built end-to-end encrypted payment infrastructure with
                <TechLink label="AWS KMS" tag="aws" tags={tags} />
                + <TechLink label="Nitro Enclaves" tags={tags} />,
                delivered a multi-tenant system for 10+ banks and 500K+ end-users,
                ensured PCI DSS and GDPR compliance, and cut fraud incidents by 25%.
              </li>
              <li>
                <strong>Bolt.SH (Cloud IaaS)</strong>: Designed an
                <TechLink label="OpenStack" tag="openstack" tags={tags} />-powered
                IaaS platform with VM orchestration, virtual networking, and load
                balancing. Reduced external data-center costs by 60% and hardened
                infrastructure with compliance-aligned access controls and audit
                logging. <a href="/bolt">Watch the series →</a>
              </li>
              <li>
                <strong>GlueStack Framework</strong>: Built a full-stack monorepo
                framework that standardized architecture across 30+ client
                projects, cut setup time by 40%, and shipped compliance-ready
                boilerplates for auth, logging, and API security.
              </li>
              <li>
                <strong>Healthcare Management System</strong>: Built a modular,
                microservice-based HMS automating scheduling, billing, and
                reporting; improved operational efficiency by 40% with
                HIPAA-compliant PHI handling and audit trails.
              </li>
              <li>
                <strong>COPPA-Compliant Social App</strong>: Developed a
                child-safety-compliant social platform backend in
                <TechLink label="Node.js" tag="nodejs" tags={tags} />,
                <TechLink label="GraphQL" tags={tags} />, and
                <TechLink label="AWS" tag="aws" tags={tags} />,
                with data anonymization and parental-consent workflows.
              </li>
              <li>Mentored 10+ engineers and drove adoption of trunk-based development with <TechLink label="GitLab CI" tag="ci-cd" tags={tags} />.</li>
            </ul>
          </div>
        </section>

        <section>
          <h2>Education</h2>
          <p>
            B.Tech in Computer Science Engineering from Dr. A. P. J. Abdul Kalam
            Technical University, Lucknow, India (2011 – 2015).
          </p>
        </section>
      </div>

      <aside class="side">
        <section>
          <h2>Core competencies</h2>
          <ul class="comp">
            {COMPETENCIES.map((g) => (
              <li>
                <strong>{g.group}</strong>:{" "}
                {g.items.map((it, i) => (
                  <Fragment>
                    {i > 0 ? ", " : ""}
                    <TechLink label={it.label} tag={it.tag} tags={tags} />
                  </Fragment>
                ))}
              </li>
            ))}
          </ul>
        </section>

        <section>
          <h2>Open source &amp; projects</h2>
          <div class="repo-grid">
            {repos.map((repo) => <RepoCard repo={repo} />)}
          </div>
          <ul>
            <li><strong>GlueStack Framework</strong>: <a href="https://github.com/gluestack" target="_blank" rel="noopener">github.com/gluestack</a> · open-source monorepo framework powering 30+ client apps.</li>
            <li><strong>Email2Webhook</strong>: <a href="https://email2webhook.com" target="_blank" rel="noopener">email2webhook.com</a> · SaaS tool converting emails into API JSON payloads.</li>
          </ul>
        </section>
      </aside>
    </div>
  </article>
</BaseLayout>

<style>
  .about { padding-top: 1.8rem; }
  .about-head { margin-bottom: 1.8rem; }
  .about-head .kicker { color: var(--text-faint); font-size: 0.85rem; margin: 0 0 0.3rem; }
  .about-head h1 { margin: 0 0 0.7rem; }
  .links { display: flex; gap: 16px; flex-wrap: wrap; margin: 0; font-size: 0.92rem; }

  .about-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.7fr) minmax(0, 1fr);
    gap: 48px;
    align-items: start;
  }
  .side { position: sticky; top: 76px; }

  .about section { margin-bottom: 2rem; }
  .main section:first-child,
  .side section:first-child { margin-top: 0; }
  .about h2 { margin-top: 0; border-bottom: 1px solid var(--border); padding-bottom: 0.3rem; }

  .comp { list-style: none; padding: 0; }
  .comp li { padding: 0.4rem 0; font-size: 0.95rem; }
  .role { margin-top: 1.3rem; }
  .role h3 { margin: 0 0 0.1rem; font-size: 1.05rem; }
  .when { color: var(--text-faint); font-size: 0.85rem; margin: 0 0 0.6rem; }
  .about ul { padding-left: 1.2rem; }
  .comp { padding-left: 0; }
  .about li { margin-bottom: 0.5rem; }
  .repo-grid { display: grid; gap: 12px; margin: 0 0 1.2rem; }

  @media (max-width: 820px) {
    .about-grid { grid-template-columns: 1fr; gap: 0; }
    .side { position: static; }
    .side section:first-child { margin-top: 2rem; }
  }
</style>
